rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      // Owner can do everything
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Shared board members can read and update tasks (move, edit)
      allow read, update: if request.auth != null && resource.data.sharedWith != null && request.auth.uid in resource.data.sharedWith;
      // Shared members can create tasks on the shared board
      allow create: if request.auth != null && request.resource.data.sharedWith != null && request.auth.uid in request.resource.data.sharedWith;
      // Shared members can delete tasks they created or on shared boards
      allow delete: if request.auth != null && resource.data.sharedWith != null && request.auth.uid in resource.data.sharedWith;
    }

    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;
    }
  }
}
